{
	"update_url": "https://clients2.google.com/service/update2/crx",
	"manifest_version": 3,
	"name": "GitHub Index Viewer",
	"description": "GitHub projelerindeki index.html dosyalarını görüntülemek için bir eklenti.",
	"version": "1.0.0",
	"icons": {
		"128": "icons/icon_128.png",
		"547": "icons/icon.png",
		"150": "icons/icon_150.png",
		"240": "icons/icon_240.png",
		"480": "icons/icon_480.png",
		"512": "icons/icon_512.png"
	},
	"action": {
		"default_title": "GitHub Index Viewer",
		"default_popup": "popup.html",
		"default_icon": "icons/icon_128.png"
	},
	"background": {
		"service_worker": "main/background.js"
	},
	"host_permissions": [
		"https://*.alperenakkaya.dev/*"
	],
	"homepage_url": "https://alperenakkaya.dev/",
	"content_scripts": [
		{
			"matches": ["*://*.github.com/*"],
			"css": ["main/styles.css"],
			"js": ["main/content.js"]
		}
	]
}
